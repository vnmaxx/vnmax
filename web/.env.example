# URL do backend para submissão pública de leads (formulário "Raio-X Digital").
# Deve apontar para o mesmo servidor que o vnmax usa (porta 8787 em dev,
# HTTPS em produção). Exemplo: https://api.vnmax.org ou http://localhost:8787
# Deixe vazio para desativar formulário de contato público.
VITE_CONTACT_API_URL=

# Integração com Studio-IA (em desenvolvimento, substituiu Nexus Digital 90)
# URL base do Studio-IA Backend (dev: http://localhost:3002 | prod: https://studio-ia-api.onrender.com)
VITE_STUDIO_API=
# TODO: Preencher com o BRIDGE_SECRET configurado no Studio-IA (variável de ambiente no Render).
# Este é um placeholder; o valor real será fornecido pela equipe do Studio-IA.
VITE_STUDIO_KEY=
