rules_version = '2';

// ============================================================
//  Regras do Firestore — RASCUNHO MESCLADO
// ============================================================
//
//  ⚠️ FUSÃO EM PROGRESSO
//  Este arquivo é um RASCUNHO da fusão de duas bases de regras:
//    - d:\vnmax\firestore.rules (base — deny-by-default, allowlist + isMember)
//    - d:\Nexus Holding\firestore.rules (atual — isAdmin baseado em claims/docs/email)
//
//  TODAS as colecões agora usam isMember() como mecanismo unificado de autenticação/
//  autorização. O antigo sistema isAdmin() foi removido.
//
//  ⚠️ INSTRUÇÕES DE DEPLOY (manual, após revisão humana):
//    1. Revise este arquivo cuidadosamente antes de deploy.
//    2. Certifique-se de que todos os UIDs necessários estão em /allowlist/{uid}
//       no projeto vnmax-6a660 (Firestore).
//    3. Publique MANUALMENTE via Firebase CLI:
//         firebase deploy --only firestore:rules
//       (Firebase project: vnmax-6a660)
//    4. NÃO execute deploy automaticamente — é uma mudança de produção que
//       requer checagem manual de acesso.
//
// ============================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Função de autorização unificada ---
    // Membro é quem está autenticado E existe em /allowlist/{uid}.
    // A allowlist é gerenciada apenas pelo console ou Admin SDK.
    function isMember() {
      return request.auth != null
        && exists(/databases/$(database)/documents/allowlist/$(request.auth.uid));
    }

    // --- Validação do lead público (schema unificado): shape fechado + tamanhos ---
    // Gravado direto pelo formulário público da landing (sem backend). Trava o
    // formato para limitar abuso: só as chaves esperadas, stage/origem fixos,
    // createdAt = timestamp do servidor, e ao menos um contato (email OU whatsapp).
    function validNewLead() {
      let d = request.resource.data;
      return
        d.keys().hasOnly(['nome','email','whatsapp','empresa','segmento','mensagem','canal','origem','stage','createdAt']) &&
        d.nome is string && d.nome.size() > 0 && d.nome.size() < 200 &&
        d.origem == 'form' &&
        d.stage == 'NOVO' &&
        d.createdAt == request.time &&
        (
          ('email' in d && d.email is string && d.email.size() > 0 && d.email.size() < 200) ||
          ('whatsapp' in d && d.whatsapp is string && d.whatsapp.size() > 0 && d.whatsapp.size() < 60)
        ) &&
        (!('email' in d) || (d.email is string && d.email.size() < 200)) &&
        (!('whatsapp' in d) || (d.whatsapp is string && d.whatsapp.size() < 60)) &&
        (!('empresa' in d) || (d.empresa is string && d.empresa.size() < 200)) &&
        (!('segmento' in d) || (d.segmento is string && d.segmento.size() < 160)) &&
        (!('mensagem' in d) || (d.mensagem is string && d.mensagem.size() < 5000)) &&
        (!('canal' in d) || (d.canal in ['email','whatsapp','instagram']));
    }

    // ============================================================
    // COLECÕES DO VNMAX (mantidas exatamente como estão)
    // ============================================================

    // Conteúdo interno reservado (portal: divisões, roadmap, produtos).
    match /internal/{doc} {
      allow read: if isMember();
      allow write: if false;          // somente Admin SDK (seed)
    }

    // Base de conhecimento interna (vnmax-os: docs/markdown).
    match /internal_docs/{doc} {
      allow read: if isMember();
      allow write: if false;          // somente Admin SDK (seed)
    }

    // Leads do CRM. Criacao PUBLICA pela landing (formulario), validada por
    // validNewLead() (shape fechado, stage/origem fixos, timestamp do servidor).
    // Membros (isMember) leem e gerenciam o funil; visitante deslogado só cria.
    match /leads/{id} {
      allow read, update, delete: if isMember();
      allow create: if validNewLead();
    }

    // Postagens sociais (aba Social): rascunho/aprovacao/publicacao. Escrita SOMENTE
    // pelo servidor (Admin SDK), que verifica o ID token. Membros apenas leem.
    match /social_posts/{id} {
      allow read: if isMember();
      allow write: if false;
    }

    // Jobs de edicao de video (aba Vídeo). Escrita so pelo servidor/worker (Admin SDK).
    match /video_jobs/{id} {
      allow read: if isMember();
      allow write: if false;
    }

    // Contas conectadas das redes (aba Social → Contas). Guardam TOKENS de acesso,
    // entao NUNCA sao lidas pelo client: todo acesso passa pelo servidor (Admin SDK),
    // que remove os segredos antes de responder. Negado a leitura/escrita pelo client.
    match /social_connections/{id} {
      allow read, write: if false;
    }

    // Estados temporarios do fluxo OAuth (code_verifier/state). Somente Admin SDK.
    match /social_oauth_states/{id} {
      allow read, write: if false;
    }

    // Allowlist de membros internos (gerenciada no console / Admin SDK).
    match /allowlist/{uid} {
      allow read, write: if false;
    }

    // ============================================================
    // COLECÕES DO NEXUS HOLDING (adaptadas para isMember())
    // ============================================================

    // Clientes CRM
    match /clientes/{clienteId} {
      allow read, write: if isMember();
    }

    // Propostas/Orçamentos
    match /propostas/{propostaId} {
      allow read, write: if isMember();
    }

    // Tarefas/To-do
    match /tarefas/{tarefaId} {
      allow read, write: if isMember();
    }

    // Campanhas de marketing
    match /campanhas/{campanhaId} {
      allow read, write: if isMember();
    }

    // Conteúdo/assets
    match /content/{contentId} {
      allow read, write: if isMember();
    }

    // Usuários/membros da equipe
    match /usuarios/{usuarioId} {
      allow read, write: if isMember();
    }

    // Histórico de ações (auditoria)
    match /historico/{entradaId} {
      allow read, write: if isMember();
    }

    // Eventos/logs
    match /eventos/{eventoId} {
      allow read, write: if isMember();
    }

    // Parcelas/Financeiro
    match /parcelas/{parcelaId} {
      allow read, write: if isMember();
    }

    // ============================================================
    // DENY-BY-DEFAULT
    // ============================================================
    // Tudo o mais é negado por padrão.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
