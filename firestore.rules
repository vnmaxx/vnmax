rules_version = '2';

// ============================================================
//  Regras do Firestore — VNMAX (projeto vnmax-6a660)
// ============================================================
//  Modelo unico: acesso interno via isMember() (autenticado + doc em
//  /allowlist/{uid}). Leads podem ser criados publicamente pela landing,
//  validados por validNewLead(). O restante e deny-by-default.
//
//  Deploy: firebase deploy --only firestore:rules --project vnmax-6a660
// ============================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Função de autorização unificada ---
    // Membro é quem está autenticado E existe em /allowlist/{uid}.
    function isMember() {
      return request.auth != null
        && exists(/databases/$(database)/documents/allowlist/$(request.auth.uid));
    }

    // --- Validação do lead público (schema unificado): shape fechado + tamanhos ---
    function validNewLead() {
      let d = request.resource.data;
      return
        d.keys().hasOnly(['nome','email','whatsapp','empresa','segmento','mensagem','canal','origem','stage','createdAt']) &&
        d.nome is string && d.nome.size() > 0 && d.nome.size() < 200 &&
        d.origem == 'form' &&
        d.stage == 'NOVO' &&
        d.createdAt == request.time &&
        (
          ('email' in d && d.email is string && d.email.size() > 0 && d.email.size() < 200) ||
          ('whatsapp' in d && d.whatsapp is string && d.whatsapp.size() > 0 && d.whatsapp.size() < 60)
        ) &&
        (!('email' in d) || (d.email is string && d.email.size() < 200)) &&
        (!('whatsapp' in d) || (d.whatsapp is string && d.whatsapp.size() < 60)) &&
        (!('empresa' in d) || (d.empresa is string && d.empresa.size() < 200)) &&
        (!('segmento' in d) || (d.segmento is string && d.segmento.size() < 160)) &&
        (!('mensagem' in d) || (d.mensagem is string && d.mensagem.size() < 5000)) &&
        (!('canal' in d) || (d.canal in ['email','whatsapp','instagram']));
    }

    // ===================== COLEÇÕES DO PORTAL (vnmax) =====================

    // Conteúdo interno reservado (portal: divisões, roadmap, produtos).
    match /internal/{doc} {
      allow read: if isMember();
      allow write: if false;          // somente Admin SDK (seed)
    }

    // Base de conhecimento interna (vnmax-os: docs/markdown).
    match /internal_docs/{doc} {
      allow read: if isMember();
      allow write: if false;          // somente Admin SDK (seed)
    }

    // Leads do CRM. Criação PÚBLICA pela landing (formulário), validada por
    // validNewLead(). Membros (isMember) leem e gerenciam o funil.
    match /leads/{id} {
      allow read, update, delete: if isMember();
      allow create: if validNewLead();
    }

    // Postagens sociais: escrita só pelo servidor (Admin SDK). Membros leem.
    match /social_posts/{id} {
      allow read: if isMember();
      allow write: if false;
    }

    // Jobs de edição de vídeo. Escrita só pelo servidor/worker (Admin SDK).
    match /video_jobs/{id} {
      allow read: if isMember();
      allow write: if false;
    }

    // Contas conectadas das redes (guardam TOKENS): nunca lidas pelo client.
    match /social_connections/{id} {
      allow read, write: if false;
    }

    // Estados temporários do fluxo OAuth. Somente Admin SDK.
    match /social_oauth_states/{id} {
      allow read, write: if false;
    }

    // Allowlist de membros internos (gerenciada no console / Admin SDK).
    match /allowlist/{uid} {
      allow read, write: if false;
    }

    // ===================== COLEÇÕES DO CRM (ex-Nexus Holding) =====================

    match /clientes/{clienteId}   { allow read, write: if isMember(); }
    match /propostas/{propostaId} { allow read, write: if isMember(); }
    match /tarefas/{tarefaId}     { allow read, write: if isMember(); }
    match /campanhas/{campanhaId} { allow read, write: if isMember(); }
    match /content/{contentId}    { allow read, write: if isMember(); }
    match /usuarios/{usuarioId}   { allow read, write: if isMember(); }
    match /historico/{entradaId}  { allow read, write: if isMember(); }
    match /eventos/{eventoId}     { allow read, write: if isMember(); }
    match /parcelas/{parcelaId}   { allow read, write: if isMember(); }

    // ===================== DENY-BY-DEFAULT =====================
    // Tudo o mais é negado por padrão.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
