rules_version = '2';

// Regras de seguranca do Firestore para a area interna da VNMAX.
//
// Modelo: o conteudo reservado fica em /internal/content. So pode ler quem estiver
// AUTENTICADO e presente na allowlist (existe um doc /allowlist/{uid}). Escrita no
// conteudo so via Admin SDK (seed). A allowlist e gerenciada apenas pelo console
// ou Admin SDK — nenhum acesso pelo client.
//
// Observacao: exists()/get() dentro das regras NAO sao limitados pelas proprias
// regras, entao consultar a allowlist funciona mesmo com /allowlist bloqueado ao client.

service cloud.firestore {
  match /databases/{database}/documents {

    function isMember() {
      return request.auth != null
        && exists(/databases/$(database)/documents/allowlist/$(request.auth.uid));
    }

    // Conteudo interno reservado (portal: divisoes, roadmap, produtos).
    match /internal/{doc} {
      allow read: if isMember();
      allow write: if false;          // somente Admin SDK (seed)
    }

    // Base de conhecimento interna (vnmax-os: docs/markdown).
    match /internal_docs/{doc} {
      allow read: if isMember();
      allow write: if false;          // somente Admin SDK (seed)
    }

    // Allowlist de membros internos (gerenciada no console / Admin SDK).
    match /allowlist/{uid} {
      allow read, write: if false;
    }

    // Tudo o mais e negado por padrao.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
