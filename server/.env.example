# Configuracao do Assistente VNMAX (servidor Linux). Copie para .env e preencha.

# Chave do NVIDIA NIM (NVIDIA Build / API Catalog). NUNCA versione este arquivo.
NVIDIA_API_KEY=

# Modelo do catalogo NVIDIA (OpenAI-compatible). Suporta tool calling.
NVIDIA_MODEL=nvidia/llama-3.3-nemotron-super-49b-v1.5

# (Opcional) Modelo dedicado para adaptar posts por rede (aba Social). Se vazio,
# reusa NVIDIA_MODEL. Use um modelo forte em copywriting/instrucao.
NVIDIA_SOCIAL_MODEL=

# --- Worker de edicao de video (aba Vídeo) — FFmpeg-only via ffmpeg-static. ---
# Rode  bash install-video.sh  (npm install) e ative aqui:
VIDEO_WORKER_ENABLED=false
# Base publica deste servidor (para montar a URL do MP4 finalizado).
VIDEO_PUBLIC_BASE=
# (Opcional) teto do download por URL, em MB.
# VIDEO_MAX_INPUT_MB=600
# (Opcional, recomendado) allowlist de hosts de origem para download (anti-SSRF).
# VIDEO_URL_ALLOWED_HOSTS=youtube.com,youtu.be,vimeo.com
# (Opcional) fonte das legendas/intro (precisa estar instalada no servidor).
# SUBTITLE_FONT=DejaVu Sans
# VIDEO_JOB_TIMEOUT_MS=1200000
# VIDEO_POLL_MS=5000

# --- Contas conectadas das redes (aba Social → Contas) — OAuth real. ---
# URL publica DESTE servidor (sem barra no fim). Necessaria para o redirect do OAuth.
# O redirect a registrar em cada app de rede e:  <PUBLIC_API_URL>/api/social/oauth/callback
PUBLIC_API_URL=
# Credenciais por rede (crie um app aprovado em cada plataforma). Sem elas, a rede
# aparece como "OAuth nao configurado" e a publicacao segue semiautomatica (abrir+colar).
# Redes OAuth suportadas: twitter, linkedin, facebook, instagram, threads, reddit,
# pinterest, tiktok, youtube, gmb. (telegram/bluesky conectam por token/manual na UI.)
# OAUTH_TWITTER_CLIENT_ID=
# OAUTH_TWITTER_CLIENT_SECRET=
# OAUTH_LINKEDIN_CLIENT_ID=
# OAUTH_LINKEDIN_CLIENT_SECRET=
# OAUTH_FACEBOOK_CLIENT_ID=
# OAUTH_FACEBOOK_CLIENT_SECRET=
# OAUTH_INSTAGRAM_CLIENT_ID=
# OAUTH_INSTAGRAM_CLIENT_SECRET=
# OAUTH_THREADS_CLIENT_ID=
# OAUTH_THREADS_CLIENT_SECRET=
# OAUTH_REDDIT_CLIENT_ID=
# OAUTH_REDDIT_CLIENT_SECRET=
# OAUTH_PINTEREST_CLIENT_ID=
# OAUTH_PINTEREST_CLIENT_SECRET=
# OAUTH_TIKTOK_CLIENT_ID=
# OAUTH_TIKTOK_CLIENT_SECRET=
# OAUTH_YOUTUBE_CLIENT_ID=
# OAUTH_YOUTUBE_CLIENT_SECRET=
# OAUTH_GMB_CLIENT_ID=
# OAUTH_GMB_CLIENT_SECRET=

# Porta do servico.
PORT=8787

# Origens do navegador autorizadas (CORS, defesa em profundidade — NAO e autenticacao,
# pois clientes nao-browser podem omitir o header Origin). Separe por virgula.
# Vazio = bloqueia todo cross-origin. Use * apenas para teste local.
ALLOWED_ORIGINS=https://vnmax.org,https://www.vnmax.org

# Token opcional do app contra abuso por scripts. Se definido, o widget precisa
# enviar o MESMO valor em VITE_CHAT_APP_TOKEN (.env do site). Nao e um segredo
# forte (vai no bundle), e so dificulta abuso casual. Deixe vazio para desativar.
APP_TOKEN=

# Confiar no header X-Forwarded-For (para rate limit por IP). Ative SOMENTE se o
# servico estiver atras de um proxy reverso confiavel que reescreve esse header.
TRUST_PROXY=false

# Criatividade do modelo (0.3 a 0.5 recomendado para atendimento).
TEMPERATURE=0.4

# Limites de seguranca (opcionais).
MAX_MESSAGES=12
MAX_CHARS=4000
MAX_TOOL_ROUNDS=3
RATE_MAX=20
RATE_WINDOW_MS=60000
REQUEST_TIMEOUT_MS=60000

# Mantem o modelo "quente" com um ping a cada N ms (reduz cold start em sites de
# baixo trafego). 0 = desligado. Ex.: 240000 = 4 min. Consome um pouco de cota.
KEEPALIVE_MS=0
