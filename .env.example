# Configuracao do Firebase (Project settings > General > Your apps > SDK setup)
# Copie este arquivo para .env e preencha com as chaves do seu projeto.
# Todas as variaveis precisam do prefixo VITE_ para o Vite expor ao client.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# URL publica (HTTPS) do Assistente VNMAX no servidor Linux (ex.: https://assistant.vnmax.org)
# Vazio = mesma origem (/api/chat). O widget chama ${VITE_CHAT_API_URL}/api/chat.
VITE_CHAT_API_URL=

# (Opcional) Token do app — deve ser igual ao APP_TOKEN do servidor, se voce usar.
VITE_CHAT_APP_TOKEN=
